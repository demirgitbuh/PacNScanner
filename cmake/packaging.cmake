# cmake/packaging.cmake — CPack configuration for all platforms.

set(CPACK_PACKAGE_NAME "PacNScanner")
set(CPACK_PACKAGE_VENDOR "PacNScanner")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "${PROJECT_DESCRIPTION}")
set(CPACK_PACKAGE_HOMEPAGE_URL "${PROJECT_HOMEPAGE_URL}")
set(CPACK_PACKAGE_VERSION "${PROJECT_VERSION}")
set(CPACK_PACKAGE_VERSION_MAJOR "${PROJECT_VERSION_MAJOR}")
set(CPACK_PACKAGE_VERSION_MINOR "${PROJECT_VERSION_MINOR}")
set(CPACK_PACKAGE_VERSION_PATCH "${PROJECT_VERSION_PATCH}")
set(CPACK_PACKAGE_CONTACT "demirgitbuh")
set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_CURRENT_SOURCE_DIR}/LICENSE")
set(CPACK_PACKAGE_INSTALL_DIRECTORY "PacNScanner")
set(CPACK_PACKAGE_EXECUTABLES "pacnscanner;PacNScanner")
set(CPACK_STRIP_FILES ON)

if(WIN32)
  # ZIP (portable) + NSIS (EXE installer) + WIX (MSI)
  set(CPACK_GENERATOR "ZIP;NSIS;WIX")
  set(CPACK_NSIS_DISPLAY_NAME "PacNScanner")
  set(CPACK_NSIS_PACKAGE_NAME "PacNScanner")
  set(CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL ON)
  set(CPACK_NSIS_MUI_FINISHPAGE_RUN "pacnscanner.exe")
  set(CPACK_NSIS_URL_INFO_ABOUT "${PROJECT_HOMEPAGE_URL}")
  set(CPACK_WIX_UPGRADE_GUID "B4F2C0A0-1E2D-4C3B-9A6E-PACNSCANNER01")
  set(CPACK_WIX_PRODUCT_GUID "*")
elseif(APPLE)
  # DragNDrop produces the .dmg; the bundle/notarization is wired in release.yml
  set(CPACK_GENERATOR "DragNDrop")
  set(CPACK_DMG_VOLUME_NAME "PacNScanner")
else()
  # Linux: DEB + RPM here; AppImage/Flatpak are produced by packaging/ scripts.
  set(CPACK_GENERATOR "DEB;RPM")
  set(CPACK_DEBIAN_PACKAGE_MAINTAINER "demirgitbuh")
  set(CPACK_DEBIAN_PACKAGE_SECTION "net")
  set(CPACK_DEBIAN_PACKAGE_SHLIBDEPS ON)
  set(CPACK_DEBIAN_PACKAGE_DEPENDS "libqt6core6, libqt6network6, libqt6widgets6, libqt6sql6")
  set(CPACK_RPM_PACKAGE_LICENSE "MIT")
  set(CPACK_RPM_PACKAGE_GROUP "Applications/Internet")
  set(CPACK_RPM_PACKAGE_REQUIRES "qt6-qtbase >= 6.5")
endif()

include(CPack)
